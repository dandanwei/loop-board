{
  "name": "loop-board",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local task board with a light SQLite DB and a no-auth local API, plus a skill that lets coding agents pull, implement, and report back on tasks.",
  "bin": {
    "loop-board": "cli/board.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "nodemon server/index.js",
    "dev:web": "vite",
    "build": "vite build",
    "start": "node server/index.js",
    "seed": "node server/seed.js",
    "cli": "node cli/board.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "cors": "^2.8.5",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@uiw/react-md-editor": "^4.0.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.9",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.11"
  }
}
